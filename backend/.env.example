# SESIS - Sistema Estatal de Control de Fuerzas Armadas
# CONFIGURACIÓN CRÍTICA - MANTENER SEGURO

# Base de datos (PostgreSQL + PostGIS + TimescaleDB)
DATABASE_URL=postgresql+asyncpg://sis_admin:CHANGE_ME_STRONG_PASSWORD@postgres:5432/sesis

# NATS JetStream (Event Bus)
NATS_URL=nats://nats:4222

# Ollama LLM (ARES Brain)
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=mistral:7b

# JWT - CLAVE DE 32+ BYTES OBLIGATORIA (generar con: openssl rand -hex 32)
JWT_SECRET_KEY=CHANGE_ME_32_PLUS_BYTES_SECRET_KEY_REQUIRED_HERE
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7
MFA_ISSUER=SESIS-CHITAURI
MFA_TOKEN_VALIDITY=300

# CORS - Orígenes permitidos (JSON array o comma-separated)
ALLOWED_ORIGINS=["http://localhost:3000","https://sis.gov.int"]

# API Keys de operadores (JSON: {key: {name, roles, clearance}})
OPERATOR_API_KEYS={"test-key-123":{"name":"Admin","roles":["admin","operator"],"clearance":"TOP_SECRET"}}

# Redis (caché + rate limiting)
REDIS_URL=redis://redis:6379/0

# MinIO / S3 (almacenamiento objetos)
MINIO_URL=http://minio:9000
MINIO_ROOT_USER=CHANGE_ME_MINIO_USER
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_STRONG_PASSWORD

# Clasificación (no cambiar)
CLASSIFICATION_LEVELS=["OPEN","RESTRICTED","CONFIDENTIAL","SECRET","TOP_SECRET"]

# JWS public key para firmas de eventos (PEM format)
JWS_PUBLIC_KEY=None

# Entorno: development | production | airgap
ENVIRONMENT=development
LOG_LEVEL=INFO

# mTLS (rutas a certificados)
MTLS_CA_CERT=None
MTLS_SERVER_CERT=None
MTLS_SERVER_KEY=None

# HSM (Hardware Security Module) - Opcional en desarrollo
HSM_ENABLED=false
HSM_LIBRARY_PATH=None
HSM_PIN=None
HSM_SLOT_ID=0

# Cifrado AES-256 (32 bytes) - generar con: openssl rand -hex 32
AES_KEY=CHANGE_ME_32_BYTE_AES_KEY_REQUIRED_HERE
